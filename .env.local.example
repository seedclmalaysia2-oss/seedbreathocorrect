# Sanity — fill in once a Sanity project is created (sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
# Editor (Editor-permission) token — powers the local inline homepage editor.
# Only needed for local development; never set this in production.
SANITY_API_WRITE_TOKEN=
# Shared secret used to validate Sanity webhook calls to /api/revalidate
SANITY_REVALIDATE_SECRET=

# Resend — for the contact form (resend.com)
RESEND_API_KEY=
# Inbox that should receive contact-form submissions
CONTACT_TO_EMAIL=
